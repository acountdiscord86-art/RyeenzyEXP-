<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>RYEENZY HUB — Premium Roblox Scripts</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
  <style>
    /* --- GLOBAL --- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #03050b;
      font-family: 'Inter', sans-serif;
      color: #eef5ff;
      overflow-x: hidden;
      line-height: 1.5;
    }

    /* Canvas particle background */
    #particle-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      z-index: 0;
      pointer-events: none;
      opacity: 0.6;
    }

    .container {
      position: relative;
      z-index: 2;
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 clamp(1rem, 5vw, 2rem);
    }

    /* --- LOADING SCREEN --- */
    .loading-screen {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: #03050b;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 1.5rem;
      transition: opacity 0.8s ease, visibility 0.8s ease;
      backdrop-filter: blur(2px);
    }
    .loading-screen.hide {
      opacity: 0;
      visibility: hidden;
    }
    .loader-logo {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: clamp(2rem, 8vw, 3rem);
      font-weight: 800;
      background: linear-gradient(135deg, #fff, #c084fc, #3b82f6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      animation: pulseLogo 1.5s infinite;
    }
    @keyframes pulseLogo {
      0%, 100% { opacity: 0.6; transform: scale(0.98);}
      50% { opacity: 1; transform: scale(1.02);}
    }
    .loader-spinner {
      width: 50px;
      height: 50px;
      border: 3px solid rgba(168, 85, 247, 0.3);
      border-top-color: #a855f7;
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .loader-text {
      font-family: 'Space Mono', monospace;
      font-size: clamp(0.8rem, 3vw, 0.9rem);
      color: #c084fc;
      letter-spacing: 2px;
      animation: fadeText 1.2s infinite alternate;
    }
    @keyframes fadeText {
      0% { opacity: 0.4; }
      100% { opacity: 1; }
    }
    .loader-bar {
      width: 200px;
      height: 2px;
      background: rgba(168, 85, 247, 0.2);
      border-radius: 99px;
      overflow: hidden;
      margin-top: 0.5rem;
    }
    .loader-bar-fill {
      width: 0%;
      height: 100%;
      background: linear-gradient(90deg, #a855f7, #c084fc);
      border-radius: 99px;
      transition: width 0.2s linear;
    }

    /* Glassmorphism core */
    .glass-card {
      background: rgba(8, 12, 25, 0.65);
      backdrop-filter: blur(14px);
      border-radius: 1.8rem;
      border: 1px solid rgba(168, 85, 247, 0.25);
      transition: all 0.3s cubic-bezier(0.2, 0.9, 0.4, 1.1);
    }

    .glass-card:hover {
      transform: translateY(-5px);
      border-color: rgba(168, 85, 247, 0.6);
      box-shadow: 0 20px 40px rgba(168, 85, 247, 0.2);
    }

    /* Navigation */
    nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.2rem 0;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo {
      font-size: clamp(1.4rem, 6vw, 1.9rem);
      font-weight: 800;
      background: linear-gradient(135deg, #fff, #c084fc, #3b82f6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.5px;
    }

    .nav-links {
      display: flex;
      gap: clamp(1rem, 3vw, 2rem);
      align-items: center;
      flex-wrap: wrap;
    }

    .nav-links a {
      color: #b9c7ff;
      text-decoration: none;
      font-weight: 500;
      font-size: clamp(0.85rem, 2.5vw, 0.95rem);
      transition: 0.2s;
    }

    .nav-links a:hover {
      color: white;
      text-shadow: 0 0 8px rgba(168, 85, 247, 0.8);
    }

    .discord-nav {
      background: linear-gradient(135deg, #5865f2, #4752c4);
      padding: 0.5rem 1.3rem;
      border-radius: 2rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: 0.2s;
    }

    .discord-nav:hover {
      transform: scale(1.02);
      box-shadow: 0 0 15px rgba(88, 101, 242, 0.5);
    }

    /* Hero */
    .hero {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: clamp(2rem, 5vw, 3rem);
      padding: clamp(2rem, 5vw, 3rem) 0 clamp(3rem, 7vw, 5rem);
    }

    .hero-left {
      flex: 1;
      min-width: 260px;
    }

    .hero-badge {
      background: rgba(168, 85, 247, 0.2);
      border-radius: 2rem;
      padding: 0.3rem 1rem;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: clamp(0.7rem, 2vw, 0.8rem);
      margin-bottom: 1rem;
      border: 1px solid rgba(168, 85, 247, 0.4);
      backdrop-filter: blur(4px);
    }

    .glitch-text {
      font-size: clamp(2rem, 8vw, 3.8rem);
      font-weight: 900;
      line-height: 1.2;
      margin-bottom: 1rem;
      position: relative;
      text-shadow: 0.03em 0 0 rgba(255, 0, 100, 0.5), -0.03em -0.02em 0 rgba(0, 255, 255, 0.5);
      animation: glitch-shake 0.2s infinite alternate;
    }

    @keyframes glitch-shake {
      0% { text-shadow: 0.03em 0 0 rgba(255, 0, 100, 0.5), -0.03em -0.02em 0 rgba(0, 255, 255, 0.5); transform: translate(0px, 0px);}
      100% { text-shadow: -0.03em 0.02em 0 rgba(255, 0, 100, 0.5), 0.03em 0.05em 0 rgba(0, 255, 255, 0.5); transform: translate(-1px, 1px);}
    }

    .hero-left p {
      font-size: clamp(0.9rem, 2.5vw, 1.1rem);
      color: #9ca3cf;
      margin-bottom: 2rem;
      max-width: 500px;
    }

    .code-block {
      background: rgba(0, 0, 0, 0.5);
      border-radius: 1rem;
      border: 1px solid rgba(168, 85, 247, 0.4);
      padding: 0.8rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .code-block pre {
      background: transparent;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
      font-family: 'Space Mono', monospace;
      font-size: clamp(0.65rem, 2vw, 0.8rem);
      color: #c084fc;
    }

    .copy-btn {
      background: linear-gradient(135deg, #a855f7, #7c3aed);
      border: none;
      padding: 0.5rem 1.2rem;
      border-radius: 2rem;
      color: white;
      font-weight: 600;
      cursor: pointer;
      transition: 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: clamp(0.75rem, 2vw, 0.85rem);
      white-space: nowrap;
    }

    .copy-btn:hover {
      transform: scale(1.02);
      box-shadow: 0 0 12px rgba(168, 85, 247, 0.6);
    }

    .hero-right {
      flex: 1;
      display: flex;
      justify-content: center;
    }

    .hero-icon {
      background: radial-gradient(circle, rgba(168, 85, 247, 0.2), transparent);
      padding: clamp(1rem, 4vw, 2rem);
      border-radius: 3rem;
      animation: pulseGlow 3s infinite;
    }

    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 20px rgba(168, 85, 247, 0.2); transform: scale(1);}
      50% { box-shadow: 0 0 40px rgba(168, 85, 247, 0.5); transform: scale(1.02);}
    }

    .hero-icon i {
      font-size: clamp(4rem, 12vw, 6rem);
      color: #fbbf24;
    }

    /* Features */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: clamp(1rem, 3vw, 2rem);
      margin: clamp(2rem, 5vw, 4rem) 0;
    }

    .feature-card {
      background: rgba(10, 15, 28, 0.6);
      backdrop-filter: blur(10px);
      border-radius: 1.5rem;
      padding: clamp(1.2rem, 4vw, 2rem) clamp(1rem, 3vw, 1.5rem);
      text-align: center;
      border: 1px solid rgba(168, 85, 247, 0.25);
      transition: all 0.3s;
    }

    .feature-card:hover {
      transform: translateY(-8px);
      border-color: #a855f7;
      box-shadow: 0 15px 30px rgba(168, 85, 247, 0.2);
    }

    .feature-card i {
      font-size: clamp(1.8rem, 6vw, 2.5rem);
      background: linear-gradient(145deg, #c084fc, #3b82f6);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      margin-bottom: 1rem;
    }

    .feature-card h3 {
      font-size: clamp(1rem, 4vw, 1.3rem);
      margin-bottom: 0.5rem;
    }

    .feature-card p {
      font-size: clamp(0.8rem, 2.5vw, 0.9rem);
      color: #b9c7ff;
    }

    /* Section titles */
    .section-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
      font-weight: 800;
      text-align: center;
      margin-bottom: 2rem;
      letter-spacing: -0.5px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    /* Scripts grid */
    .script-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: clamp(1rem, 3vw, 2rem);
      margin-bottom: clamp(2rem, 5vw, 4rem);
    }

    .script-card {
      background: rgba(15, 22, 40, 0.7);
      backdrop-filter: blur(8px);
      border-radius: 1.5rem;
      padding: clamp(1rem, 4vw, 1.8rem);
      border: 1px solid rgba(168, 85, 247, 0.2);
      transition: all 0.3s;
    }

    .script-card:hover {
      transform: translateY(-6px);
      border-color: #a855f7;
      box-shadow: 0 15px 30px rgba(168, 85, 247, 0.15);
    }

    .script-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.8rem;
      flex-wrap: wrap;
      gap: 8px;
    }

    .script-name {
      font-size: clamp(1.2rem, 5vw, 1.6rem);
      font-weight: 700;
      background: linear-gradient(135deg, #fff, #c084fc);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .free-tag {
      background: rgba(16, 185, 129, 0.2);
      border: 1px solid #10b981;
      border-radius: 2rem;
      padding: 0.2rem 0.8rem;
      font-size: 0.7rem;
      font-weight: 600;
    }

    .script-desc {
      color: #b9c7ff;
      font-size: clamp(0.8rem, 2.5vw, 0.9rem);
      margin: 1rem 0;
    }

    .script-code {
      background: #00000055;
      padding: 0.8rem;
      border-radius: 1rem;
      font-family: 'Space Mono', monospace;
      font-size: clamp(0.6rem, 2vw, 0.7rem);
      word-break: break-all;
      margin: 1rem 0;
      cursor: pointer;
      transition: 0.2s;
    }

    .script-code:hover {
      background: #000000aa;
    }

    /* Dual section (executor + pricing) */
    .dual-section {
      display: flex;
      flex-wrap: wrap;
      gap: clamp(1rem, 3vw, 2rem);
      margin: clamp(2rem, 5vw, 3rem) 0;
    }

    .dual-card {
      flex: 1;
      min-width: 260px;
      background: rgba(10, 15, 28, 0.7);
      backdrop-filter: blur(12px);
      border-radius: 1.5rem;
      padding: clamp(1rem, 4vw, 1.8rem);
      border: 1px solid #2d3a6e;
    }

    .dual-card h3 {
      font-size: clamp(1.1rem, 4vw, 1.4rem);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .executor-list {
      list-style: none;
      margin-top: 1rem;
    }

    .executor-list li {
      padding: 0.7rem 0;
      display: flex;
      align-items: center;
      gap: 12px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      transition: 0.2s;
      font-size: clamp(0.85rem, 2.5vw, 0.95rem);
    }

    .executor-list li i:first-child {
      width: 24px;
      color: #c084fc;
    }

    .executor-list li:hover {
      transform: translateX(5px);
      color: #c084fc;
    }

    .pricing-plan {
      background: #0f1222;
      border-radius: 1rem;
      padding: 1rem 1.2rem;
      margin-bottom: 1rem;
      border-left: 4px solid #a855f7;
    }

    /* Live status */
    .live-section {
      margin: clamp(2rem, 5vw, 3rem) 0;
    }

    .live-card {
      background: rgba(8, 12, 25, 0.7);
      backdrop-filter: blur(12px);
      border-radius: 1.5rem;
      border: 1px solid rgba(168, 85, 247, 0.25);
      overflow: hidden;
    }

    .live-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
      padding: clamp(0.8rem, 3vw, 1.2rem) clamp(1rem, 4vw, 1.5rem);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .live-dot {
      width: 8px;
      height: 8px;
      background: #22c55e;
      border-radius: 50%;
      display: inline-block;
      box-shadow: 0 0 8px #22c55e;
      animation: pulse 1.5s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }

    .live-tabs {
      display: flex;
      gap: 0.5rem;
      padding: 0.5rem clamp(1rem, 4vw, 1.5rem);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      flex-wrap: wrap;
    }

    .ltab {
      background: transparent;
      border: 1px solid rgba(168, 85, 247, 0.3);
      padding: 0.4rem 0.9rem;
      border-radius: 2rem;
      color: #cbd5ff;
      cursor: pointer;
      transition: 0.2s;
      font-weight: 600;
      font-size: clamp(0.75rem, 2vw, 0.85rem);
    }

    .ltab.on {
      background: rgba(168, 85, 247, 0.2);
      border-color: #a855f7;
      color: #fff;
    }

    .live-body {
      padding: clamp(1rem, 4vw, 1.5rem);
    }

    .live-row {
      display: flex;
      justify-content: space-between;
      padding: 0.8rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      font-size: clamp(0.85rem, 2.5vw, 0.95rem);
    }

    /* FAQ */
    .faq-section {
      margin: clamp(2rem, 5vw, 4rem) 0;
    }

    .faq-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }

    .faq-item {
      background: rgba(0, 0, 0, 0.3);
      border-radius: 1rem;
      padding: 1.2rem;
    }

    .faq-item strong {
      display: block;
      margin-bottom: 0.5rem;
      font-size: clamp(0.9rem, 2.8vw, 1rem);
    }

    .faq-item p {
      font-size: clamp(0.8rem, 2.5vw, 0.9rem);
      color: #b9c7ff;
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 2rem;
      border-top: 1px solid #1e293b;
      margin-top: 2rem;
      font-size: clamp(0.7rem, 2vw, 0.8rem);
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 25px;
      right: 25px;
      background: #1e293bdd;
      backdrop-filter: blur(10px);
      padding: 12px 24px;
      border-radius: 60px;
      font-weight: 600;
      z-index: 1000;
      transform: translateX(400px);
      transition: 0.3s;
      border-left: 4px solid #a855f7;
      font-size: clamp(0.8rem, 2vw, 0.9rem);
    }

    .toast.show {
      transform: translateX(0);
    }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.7s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
      .hero-left, .hero-right {
        text-align: center;
      }
      .hero-left p {
        margin-left: auto;
        margin-right: auto;
      }
      .code-block {
        flex-direction: column;
        align-items: stretch;
      }
      .code-block pre {
        text-align: center;
      }
      .copy-btn {
        justify-content: center;
      }
      .nav-links {
        justify-content: center;
        width: 100%;
      }
      .logo {
        text-align: center;
        width: 100%;
      }
    }
  </style>
</head>
